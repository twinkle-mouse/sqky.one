---
import type { CollectionEntry } from "astro:content";

type Props = {
    entry: CollectionEntry<"writings">;
};

const { entry } = Astro.props;
---

<div class="entry-description" set:html={entry.data.description} />

<style>
    .entry-description {
        font-family: var(--sans);
        font-style: italic;

        color: var(--lavender200);
    }
</style>
