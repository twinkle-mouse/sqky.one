---
import Section from "$layouts/Section.astro";

import AboutMeContent from "./AboutMe.mdx";
import AboutMeContentMisc from "./AboutMeMisc.mdx";
import AboutMeContentMore from "./AboutMeMore.mdx";
import Hearts from "./Hearts.astro";
---

<Section id="about-me">
    <AboutMeContent />

    <section>
        <h3>By The Way, There’s More</h3>

        <div class="by-the-way">
            <div class="by-the-way-text" data-emoji-is-contentful="true">
                <AboutMeContentMore />
            </div>

            <div class="by-the-way-hearts-container">
                <div class="by-the-way-hearts">
                    <Hearts />
                </div>
            </div>
        </div>

        <style>
            .by-the-way {
                display: flex;
                flex-wrap: wrap;
            }

            .by-the-way-text {
                width: fit-content;
                flex: 1 1 420px;
            }

            .by-the-way-hearts-container {
                overflow-x: auto;
                flex: 1 1 300px;

                margin-top: 2.5rem;
                margin-bottom: 4rem;
                margin-inline: 2.5rem;
            }

            .by-the-way-hearts {
                width: max-content;
                height: max-content;
                margin-inline: auto;
            }
        </style>
    </section>

    <AboutMeContentMisc />
</Section>
