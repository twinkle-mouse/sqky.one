---
import RssSvg from "$assets/icons/rss.svg";
---

<a href="/rss.xml">
    <RssSvg width={32} height={32} class="rss-icon" role="img"><title>Subscribe to the Squeakenings (RSS)</title></RssSvg>
</a>

<style>
    .rss-icon {
        color: rgb(255, 199, 96);
    }

    @media (prefers-color-scheme: light) {
        .rss-icon {
            color: rgb(233, 151, 0);
        }
    }
</style>
