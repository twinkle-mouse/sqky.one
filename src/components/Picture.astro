---
import El, { type Props as P } from "astro/components/Picture.astro";

export type Props = P & {
    densities?: (number | `${number}x`)[];
    widths?: never;
    layout?: never;
};

const { alt, ...props } = Astro.props;
props.formats = props.formats ?? ["webp", "avif", "png"];
---

<El alt={alt!} quality="max" fallbackFormat={props.formats?.[0]} densities={[1.0, 0.75, 0.5, 0.25]} {...props} />
